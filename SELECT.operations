import sqlite3

conn = sqlite3.connect("student.db")
cursor = conn.cursor()

# INSERT
cursor.execute("INSERT INTO students (name, age) VALUES (?, ?)", ("anuj", 20))

# UPDATE
cursor.execute("UPDATE students SET age = 21 WHERE name = 'anuj'")

# SELECT
cursor.execute("SELECT * FROM students")
rows = cursor.fetchall()

print("Records:")
for row in rows:
    print(row)

# DELETE
cursor.execute("DELETE FROM students WHERE name = 'anuj'")

conn.commit()
conn.close()
